---
import type { Author } from "../types/types";

interface Props {
  authors: Author[];
}

const { authors } = Astro.props;
---



<div class="flex flex-row gap-x-8 gap-y-4 flex-wrap justify-center">
  {
    authors.map((author) => (
      <div class="flex flex-col items-center text-center">
        <span class="text-xl flex flex-row">
          {author.url ? (
            <a href={author.url} class="hover:underline text-blue-600">
              {author.name}
            </a>
          ) : (
            author.name
          )}
          {author.notes && (
            <sup class="text-sm ml-0.5">
              {author.notes.map(
                (note, index, array) =>
                  note + (index < array.length - 1 ? "," : "")
              )}
            </sup>
          )}
        </span>
        
        {author.email && (
          <a href={`mailto:${author.email}`} class="text-sm text-gray-500 hover:text-gray-700">
            {author.email}
          </a>
        )}

        {author.institution && <p class="text-sm">{author.institution}</p>}
      </div>
    ))
  }
</div>
